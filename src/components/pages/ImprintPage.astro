---
import LegalPage from './LegalPage.astro';
import { defaultLang } from '../../i18n/ui';
const lang = Astro.currentLocale ?? defaultLang;
const de = lang === 'de';
---
{de ? (
<LegalPage eyebrow="Rechtliches" title="Impressum">
  <h2>Angaben gemäß § 5 DDG</h2>
  <p>
    LUMA <mark>[Rechtsform eintragen, z. B. GbR/GmbH]</mark><br />
    <mark>[Straße + Hausnummer eintragen]</mark><br />
    <mark>[PLZ]</mark> Eberswalde<br />
    Deutschland
  </p>
  <h2>Vertreten durch</h2>
  <p>Malte Larsen, Lukas Steingässer</p>
  <h2>Kontakt</h2>
  <p>E-Mail: info@luma.earth<br />Telefon: <mark>[Telefonnummer eintragen]</mark></p>
  <h2>Umsatzsteuer</h2>
  <p>Umsatzsteuer-Identifikationsnummer gemäß § 27 a UStG: <mark>[USt-IdNr. eintragen oder Abschnitt entfernen]</mark></p>
  <h2>Verantwortlich für den Inhalt nach § 18 Abs. 2 MStV</h2>
  <p>Malte Larsen, Lukas Steingässer (Anschrift wie oben)</p>
  <h2>Streitschlichtung</h2>
  <p>Die Europäische Kommission stellt eine Plattform zur Online-Streitbeilegung (OS) bereit: https://ec.europa.eu/consumers/odr/. Wir sind nicht bereit oder verpflichtet, an Streitbeilegungsverfahren vor einer Verbraucherschlichtungsstelle teilzunehmen.</p>
  <h2>Haftung für Inhalte &amp; Links</h2>
  <p>Als Diensteanbieter sind wir für eigene Inhalte auf diesen Seiten nach den allgemeinen Gesetzen verantwortlich. Für Inhalte externer Links übernehmen wir keine Gewähr; für sie ist stets der jeweilige Anbieter verantwortlich.</p>
</LegalPage>
) : (
<LegalPage eyebrow="Legal" title="Imprint" note="This imprint is provided under German law (§ 5 DDG). The German version is authoritative.">
  <h2>Provider</h2>
  <p>
    LUMA <mark>[legal form]</mark><br />
    <mark>[street + number]</mark><br />
    <mark>[postal code]</mark> Eberswalde, Germany
  </p>
  <h2>Represented by</h2>
  <p>Malte Larsen, Lukas Steingässer</p>
  <h2>Contact</h2>
  <p>Email: info@luma.earth<br />Phone: <mark>[phone number]</mark></p>
  <h2>VAT ID</h2>
  <p>VAT identification number according to § 27 a UStG: <mark>[VAT ID or remove section]</mark></p>
</LegalPage>
)}
