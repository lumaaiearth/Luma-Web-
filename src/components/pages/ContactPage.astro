---
import { useP } from '../../i18n/pages';
import { useT, defaultLang } from '../../i18n/ui';
import ContactForm from '../ContactForm.astro';
const lang = Astro.currentLocale ?? defaultLang;
const p = useP(lang).contact;
const t = useT(lang);
---
<section class="pagehero"><div class="wrap">
  <span class="eyebrow">{p.eyebrow}</span>
  <h1>{p.title}</h1>
  <p>{p.lead}</p>
</div></section>

<section class="prose"><div class="wrap">
  <div class="cont">
    <div class="cinfo">
      <b>LUMA</b>
      <p>{t.contact.address}<br /><a href="mailto:info@luma.earth">info@luma.earth</a></p>
    </div>
    <ContactForm />
  </div>
</div></section>
