---
import '../styles/global.css';
import { useT, defaultLang } from '../i18n/ui';

const lang = Astro.currentLocale ?? defaultLang;
const t = useT(lang);
const isDe = lang === 'de';
const base = import.meta.env.BASE_URL; // '/' oder '/Luma-Web-/'
const home = base;
const en = base + 'en/';
const imgKeys = ['hero', 'greenroof', 'facade', 'macro', 'arborist', 'aerial', 'planting'];
const imgCss = ':root{' + imgKeys.map((k) => `--img-${k}:url("${base}images/${k}.jpg")`).join(';') + '}';
const favicon =
  "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Ccircle cx='16' cy='16' r='11' fill='%2339B368'/%3E%3C/svg%3E";
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{t.meta.title}</title>
    <meta name="description" content={t.meta.description} />
    <link rel="icon" href={favicon} />
    <style is:inline set:html={imgCss}></style>
    <meta property="og:title" content={t.meta.title} />
    <meta property="og:description" content={t.meta.description} />
    <meta property="og:type" content="website" />
  </head>
  <body>
    <nav id="nav">
      <div class="nav-in">
        <a href={isDe ? home : en} class="logo"><span class="d"></span>LUMA</a>
        <div class="nav-links">
          <a href="#leistungen">{t.nav.services}</a>
          <a href="#projekte">{t.nav.projects}</a>
          <a href="#journal">{t.nav.journal}</a>
          <a href="#ueber">{t.nav.about}</a>
          <a href="#kontakt">{t.nav.contact}</a>
        </div>
        <div class="nav-right">
          <span class="lang">
            {isDe ? <b>DE</b> : <a href={home}>DE</a>} · {isDe ? <a href={en}>EN</a> : <b>EN</b>}
          </span>
          <button class="ttoggle" id="tg" aria-label="Theme">◐</button>
          <a href="https://luma-biome.de" target="_blank" rel="noopener" class="btn btn-light">{t.nav.ops}</a>
        </div>
      </div>
    </nav>

    <slot />

    <footer>
      <div class="foot">
        <div>
          <div class="logo"><span class="d"></span>LUMA</div>
          <p>{t.footer.tagline}</p>
        </div>
        <div>
          <h4>{t.footer.colServices}</h4>
          <a href="#leistungen">{t.services.items[0].h}</a>
          <a href="#leistungen">{t.services.items[2].h}</a>
          <a href="#leistungen">{t.services.items[5].h}</a>
          <a href="#leistungen">{t.services.items[6].h}</a>
        </div>
        <div>
          <h4>{t.footer.colCompany}</h4>
          <a href="#projekte">{t.nav.projects}</a>
          <a href="#ueber">{t.nav.about}</a>
          <a href="#journal">{t.nav.journal}</a>
          <a href="https://luma-biome.de" target="_blank" rel="noopener">{t.footer.opsLogin}</a>
        </div>
        <div>
          <h4>{t.footer.colLegal}</h4>
          <a href="#">{t.footer.imprint}</a>
          <a href="#">{t.footer.privacy}</a>
          <a href="#">{t.footer.terms}</a>
          <a href="#" id="cookieopen">{t.footer.cookies}</a>
        </div>
      </div>
      <div class="foot-b">
        <span>{t.footer.rights}</span>
        <span class="mono">{lang.toUpperCase()} · luma.earth</span>
      </div>
    </footer>

    <div class="cookie" id="cookie">
      <p set:html={t.cookie.text}></p>
      <div class="cb">
        <button class="btn btn-primary" id="ckAccept">{t.cookie.accept}</button>
        <button class="btn btn-ghost" id="ckDecline">{t.cookie.decline}</button>
      </div>
    </div>

    <script is:inline>
      (function () {
        var root = document.documentElement,
          nav = document.getElementById('nav'),
          tg = document.getElementById('tg');
        function sys() { return matchMedia('(prefers-color-scheme:dark)').matches ? 'dark' : 'light'; }
        function set(x) { root.setAttribute('data-theme', x); tg.textContent = x === 'dark' ? '◑' : '◐'; }
        var saved = localStorage.getItem('luma-theme');
        set(saved || sys());
        tg.addEventListener('click', function () {
          var next = (root.getAttribute('data-theme') || sys()) === 'dark' ? 'light' : 'dark';
          set(next); localStorage.setItem('luma-theme', next);
        });
        function onScroll() { nav.classList.toggle('solid', scrollY > 60); }
        onScroll(); addEventListener('scroll', onScroll, { passive: true });
        var ck = document.getElementById('cookie');
        if (localStorage.getItem('luma-cookie')) ck.style.display = 'none';
        function close(v) { ck.style.display = 'none'; localStorage.setItem('luma-cookie', v); }
        document.getElementById('ckAccept').onclick = function () { close('all'); };
        document.getElementById('ckDecline').onclick = function () { close('essential'); };
        document.getElementById('cookieopen').onclick = function (e) { e.preventDefault(); ck.style.display = 'block'; };
      })();
    </script>
  </body>
</html>
